{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "export DOYAKEN_DIR=\"${DOYAKEN_DIR:-$HOME/work/doyaken}\"; bash \"$DOYAKEN_DIR/hooks/load-ticket-context.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "export DOYAKEN_DIR=\"${DOYAKEN_DIR:-$HOME/work/doyaken}\"; DOYAKEN_GUARD_EVENT=bash python3 \"$DOYAKEN_DIR/hooks/guard-handler.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "export DOYAKEN_DIR=\"${DOYAKEN_DIR:-$HOME/work/doyaken}\"; DOYAKEN_GUARD_EVENT=file python3 \"$DOYAKEN_DIR/hooks/guard-handler.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "export DOYAKEN_DIR=\"${DOYAKEN_DIR:-$HOME/work/doyaken}\"; bash \"$DOYAKEN_DIR/hooks/post-commit-guard.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "export DOYAKEN_DIR=\"${DOYAKEN_DIR:-$HOME/work/doyaken}\"; bash \"$DOYAKEN_DIR/hooks/phase-loop.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "export DOYAKEN_DIR=\"${DOYAKEN_DIR:-$HOME/work/doyaken}\"; bash \"$DOYAKEN_DIR/hooks/pre-compact.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "export DOYAKEN_DIR=\"${DOYAKEN_DIR:-$HOME/work/doyaken}\"; bash \"$DOYAKEN_DIR/hooks/session-end.sh\""
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": ["node_modules", ".venv", "vendor", "target", ".next", ".nuxt"]
  }
}
